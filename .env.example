# SAD-SMARTER B3 — Environment Variables
# Copy this file to .env and fill in your values

# Flask
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-random-secret-key

# Database
DATABASE_URL=sqlite:///sad_smarter.db

# brapi.dev API
BRAPI_TOKEN=your_brapi_token_here
BRAPI_BASE_URL=https://brapi.dev/api

# Data Collection Schedule (hours)
COLLECTION_INTERVAL_HOURS=24

# Rate limiting (seconds between API requests)
API_RATE_LIMIT_SECONDS=1.0
